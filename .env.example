# Frontend (exposed to the browser by Vite) — public API base of the InsForge project.
# The RAG edge functions are reached at ${VITE_INSFORGE_API_URL}/functions/<slug>.
VITE_INSFORGE_API_URL=https://your-project.region.insforge.app

# Server-side only (NEVER prefix with VITE_). Provisioned with `npx @insforge/cli ai setup`.
OPENROUTER_API_KEY=sk-or-v1-...
